<?xml version="1.0" encoding="utf-8"?>
<!--
    MainWindow.xaml — Główny shell aplikacji Nexus.
    Layout 3-kolumnowy: NavigationView (sidebar) + Content (Frame) + RightPanel.
    Wzorowany na design/Layout.tsx + Sidebar.tsx + RightPanel.tsx.
-->
<Window
    x:Class="Nexus.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Nexus"
    xmlns:vm="using:Nexus.ViewModels"
    xmlns:models="using:Nexus.Models"
    Title="Nexus — SocialPlatform.App">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

        <Grid Background="{StaticResource NexusBackgroundBrush}" x:Name="RootLayout">
        <Grid.RowDefinitions>
            <!-- Pasek tytułu (TitleBar) -->
            <RowDefinition Height="40" />
            <!-- Główna zawartość -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══════════ PASEK TYTUŁU ═══════════ -->
        <!-- Odpowiednik TitleBar.tsx — logo, wyszukiwarka, nazwa app -->
        <Grid Grid.Row="0"
              Background="{StaticResource NexusBackgroundBrush}"
              BorderBrush="{StaticResource NexusBorderBrush}"
              BorderThickness="0,0,0,1"
              Padding="12,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Logo i nazwa -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                <Border Background="{StaticResource NexusVioletBrush}"
                        CornerRadius="4" Width="20" Height="20">
                    <FontIcon Glyph="&#xF0E2;" FontSize="10"
                              Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="Nexus" FontWeight="SemiBold" FontSize="12"
                           Foreground="{StaticResource NexusForegroundBrush}"
                           VerticalAlignment="Center" />
                <TextBlock Text="— SocialPlatform.App" FontSize="11"
                           Foreground="{StaticResource NexusMutedForegroundBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- Wyszukiwarka globalna -->
            <TextBox Grid.Column="1"
                     PlaceholderText="Szukaj na Nexus (Ctrl+K)"
                     Style="{StaticResource NexusSearchBoxStyle}"
                     MaxWidth="400" Margin="24,0"
                     VerticalAlignment="Center"
                     Height="28" />
        </Grid>

        <!-- ═══════════ GŁÓWNA ZAWARTOŚĆ ═══════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Sidebar nawigacji -->
                <ColumnDefinition Width="240" />
                <!-- Separator -->
                <ColumnDefinition Width="Auto" />
                <!-- Główna treść -->
                <ColumnDefinition Width="*" />
                <!-- Separator -->
                <ColumnDefinition Width="Auto" />
                <!-- Prawy panel -->
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <!-- ═══════════ SIDEBAR (Sidebar.tsx) ═══════════ -->
            <Grid Grid.Column="0" Background="{StaticResource NexusSidebarBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Etykieta "NAWIGACJA" -->
                <TextBlock Grid.Row="0" Text="NAWIGACJA"
                           Style="{StaticResource NexusSectionLabelStyle}"
                           Margin="16,16,16,4" />

                <!-- Pozycje nawigacyjne -->
                <ListView Grid.Row="1"
                           x:Name="NavListView"
                           SelectionMode="Single"
                           Margin="8,4,8,0"
                           Background="Transparent"
                           SelectionChanged="NavListView_SelectionChanged">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="8,6" />
                            <Setter Property="Margin" Value="0,1" />
                            <Setter Property="CornerRadius" Value="4" />
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.Items>
                        <!-- Strona główna -->
                        <ListViewItem Tag="home">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE80F;" FontSize="16"
                                          Foreground="{StaticResource NexusMutedForegroundBrush}" />
                                <TextBlock Text="Strona główna" FontSize="13"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </ListViewItem>
                        <!-- Odkrywaj -->
                        <ListViewItem Tag="explore">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE721;" FontSize="16"
                                          Foreground="{StaticResource NexusMutedForegroundBrush}" />
                                <TextBlock Text="Odkrywaj" FontSize="13"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </ListViewItem>
                        <!-- Powiadomienia -->
                        <ListViewItem Tag="notifications">
                            <Grid>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xEA8F;" FontSize="16"
                                              Foreground="{StaticResource NexusMutedForegroundBrush}" />
                                    <TextBlock Text="Powiadomienia" FontSize="13"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <!-- Badge z liczbą powiadomień -->
                                <Border Style="{StaticResource NexusBadgeStyle}"
                                        HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock Text="3" FontSize="10" FontWeight="SemiBold"
                                               Foreground="White" HorizontalAlignment="Center" />
                                </Border>
                            </Grid>
                        </ListViewItem>
                        <!-- Wiadomości -->
                        <ListViewItem Tag="messages">
                            <Grid>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE715;" FontSize="16"
                                              Foreground="{StaticResource NexusMutedForegroundBrush}" />
                                    <TextBlock Text="Wiadomości" FontSize="13"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <Border Style="{StaticResource NexusBadgeStyle}"
                                        HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock Text="12" FontSize="10" FontWeight="SemiBold"
                                               Foreground="White" HorizontalAlignment="Center" />
                                </Border>
                            </Grid>
                        </ListViewItem>
                        <!-- Zakładki -->
                        <ListViewItem Tag="bookmarks">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE8A4;" FontSize="16"
                                          Foreground="{StaticResource NexusMutedForegroundBrush}" />
                                <TextBlock Text="Zakładki" FontSize="13"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </ListViewItem>
                        <!-- Profil -->
                        <ListViewItem Tag="profile">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE77B;" FontSize="16"
                                          Foreground="{StaticResource NexusMutedForegroundBrush}" />
                                <TextBlock Text="Profil" FontSize="13"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </ListViewItem>
                        <!-- Ustawienia -->
                        <ListViewItem Tag="settings">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE713;" FontSize="16"
                                          Foreground="{StaticResource NexusMutedForegroundBrush}" />
                                <TextBlock Text="Ustawienia" FontSize="13"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </ListViewItem>
                    </ListView.Items>
                </ListView>

                <!-- Przycisk "Napisz post" -->
                <Button Grid.Row="2"
                        Style="{StaticResource NexusPrimaryButtonStyle}"
                        HorizontalAlignment="Stretch"
                        Margin="12,8"
                        Click="ComposeButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE70F;" FontSize="14" Foreground="White" />
                        <TextBlock Text="Napisz post" FontSize="13" FontWeight="SemiBold" />
                    </StackPanel>
                </Button>

                <!-- Profil użytkownika na dole sidebara -->
                <Border Grid.Row="3"
                        Margin="8,4,8,8" Padding="8"
                        CornerRadius="4"
                        BorderBrush="{StaticResource NexusBorderBrush}"
                        BorderThickness="1"
                        Background="Transparent">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Awatar -->
                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18">
                            <Border.Background>
                                <ImageBrush Stretch="UniformToFill">
                                    <ImageBrush.ImageSource>
                                        <BitmapImage UriSource="https://images.unsplash.com/photo-1543132220-e7fef0b974e7?crop=entropy&amp;cs=tinysrgb&amp;fit=max&amp;fm=jpg&amp;q=80&amp;w=200"
                                                     CreateOptions="IgnoreImageCache" />
                                    </ImageBrush.ImageSource>
                                </ImageBrush>
                            </Border.Background>
                        </Border>

                        <!-- Dane użytkownika -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="0">
                            <TextBlock Text="Marek Kowalski" FontWeight="SemiBold" FontSize="12"
                                       Foreground="{StaticResource NexusForegroundBrush}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="@marekdev · online" FontSize="11"
                                       Foreground="{StaticResource NexusMutedForegroundBrush}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <!-- Zielona kropka "online" -->
                        <Ellipse Grid.Column="2" Width="8" Height="8"
                                 Fill="{StaticResource NexusGreenBrush}"
                                 VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </Grid>

            <!-- Separator lewy -->
            <Border Grid.Column="1" Width="1" Background="{StaticResource NexusBorderBrush}" />

            <!-- ═══════════ GŁÓWNA TREŚĆ (Frame) ═══════════ -->
            <Frame Grid.Column="2" x:Name="ContentFrame"
                   Background="{StaticResource NexusCardBrush}" />

            <!-- Separator prawy -->
            <Border Grid.Column="3" Width="1" Background="{StaticResource NexusBorderBrush}" />

            <!-- ═══════════ PRAWY PANEL (RightPanel.tsx) ═══════════ -->
            <ScrollViewer Grid.Column="4" Background="{StaticResource NexusSidebarBrush}"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Padding="12" Spacing="12">

                    <!-- Popularne hashtagi -->
                    <Border Style="{StaticResource NexusCardStyle}">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8B1;" FontSize="14"
                                          Foreground="{StaticResource NexusVioletLightBrush}" />
                                <TextBlock Text="Popularne hashtagi" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource NexusForegroundBrush}" />
                            </StackPanel>

                            <!-- #CSharp -->
                            <Border Padding="8,6" CornerRadius="3"
                                    BorderBrush="{StaticResource NexusBorderBrush}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xF0E2;" FontSize="12"
                                              Foreground="{StaticResource NexusVioletLightBrush}"
                                              Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Technologia" FontSize="10"
                                                   Foreground="{StaticResource NexusMutedForegroundBrush}" />
                                        <TextBlock Text="#CSharp" FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{StaticResource NexusForegroundBrush}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="12.4K" FontSize="11"
                                               Foreground="{StaticResource NexusMutedForegroundBrush}"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <!-- #DotNet9 -->
                            <Border Padding="8,6" CornerRadius="3"
                                    BorderBrush="{StaticResource NexusBorderBrush}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xF0E2;" FontSize="12"
                                              Foreground="{StaticResource NexusVioletLightBrush}"
                                              Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Programowanie" FontSize="10"
                                                   Foreground="{StaticResource NexusMutedForegroundBrush}" />
                                        <TextBlock Text="#DotNet9" FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{StaticResource NexusForegroundBrush}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="8.7K" FontSize="11"
                                               Foreground="{StaticResource NexusMutedForegroundBrush}"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <!-- #GameDev -->
                            <Border Padding="8,6" CornerRadius="3"
                                    BorderBrush="{StaticResource NexusBorderBrush}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xF0E2;" FontSize="12"
                                              Foreground="{StaticResource NexusVioletLightBrush}"
                                              Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Gaming" FontSize="10"
                                                   Foreground="{StaticResource NexusMutedForegroundBrush}" />
                                        <TextBlock Text="#GameDev" FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{StaticResource NexusForegroundBrush}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="5.2K" FontSize="11"
                                               Foreground="{StaticResource NexusMutedForegroundBrush}"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <!-- #AI -->
                            <Border Padding="8,6" CornerRadius="3"
                                    BorderBrush="{StaticResource NexusBorderBrush}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xF0E2;" FontSize="12"
                                              Foreground="{StaticResource NexusVioletLightBrush}"
                                              Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Technologia" FontSize="10"
                                                   Foreground="{StaticResource NexusMutedForegroundBrush}" />
                                        <TextBlock Text="#AI" FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{StaticResource NexusForegroundBrush}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="34.1K" FontSize="11"
                                               Foreground="{StaticResource NexusMutedForegroundBrush}"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <!-- #OpenSource -->
                            <Border Padding="8,6" CornerRadius="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="&#xF0E2;" FontSize="12"
                                              Foreground="{StaticResource NexusVioletLightBrush}"
                                              Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Społeczność" FontSize="10"
                                                   Foreground="{StaticResource NexusMutedForegroundBrush}" />
                                        <TextBlock Text="#OpenSource" FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{StaticResource NexusForegroundBrush}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="3.8K" FontSize="11"
                                               Foreground="{StaticResource NexusMutedForegroundBrush}"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Kogo obserwować -->
                    <Border Style="{StaticResource NexusCardStyle}">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8FA;" FontSize="14"
                                          Foreground="{StaticResource NexusVioletLightBrush}" />
                                <TextBlock Text="Kogo obserwować" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource NexusForegroundBrush}" />
                            </StackPanel>

                            <ItemsRepeater ItemsSource="{Binding ViewModel.SuggestedUsers}">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="models:SuggestedUser">
                                        <Grid ColumnSpacing="8" DataContext="{x:Bind}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                                                    BorderBrush="{StaticResource NexusBorderBrush}" BorderThickness="1">
                                                <Border.Background>
                                                    <ImageBrush Stretch="UniformToFill">
                                                        <ImageBrush.ImageSource>
                                                            <BitmapImage UriSource="{x:Bind AvatarUrl}" CreateOptions="IgnoreImageCache" />
                                                        </ImageBrush.ImageSource>
                                                    </ImageBrush>
                                                </Border.Background>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="12"
                                                           Foreground="{StaticResource NexusForegroundBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding AtLogin}" FontSize="11"
                                                           Foreground="{StaticResource NexusMutedForegroundBrush}" />
                                            </StackPanel>
                                            <Button Grid.Column="2" Style="{StaticResource NexusPrimaryButtonStyle}"
                                                    Padding="10,4" FontSize="11"
                                                    Click="FollowButton_Click" Tag="{Binding}">
                                                <TextBlock Text="{Binding IsFollowing, Converter={StaticResource FollowButtonTextConverter}}" FontSize="11" FontWeight="SemiBold" />
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </Border>

                    <!-- Stopka -->
                    <TextBlock Text="© 2026 Nexus · SocialPlatform.App · WinUI 3"
                               FontSize="10"
                               Foreground="{StaticResource NexusMutedForegroundBrush}"
                               Margin="4,8,0,0" />

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
