using System.Collections.Generic;

namespace Nexus.Data.Entities;

public class UserEntity
{
    public int Id { get; set; }
    public string Login { get; set; } = string.Empty;
    public string Email { get; set; } = string.Empty;
    public string PasswordHash { get; set; } = string.Empty;

    public UserProfileEntity? Profile { get; set; }
    public ICollection<PostEntity> Posts { get; set; } = new List<PostEntity>();
    public ICollection<NotificationEntity> Notifications { get; set; } = new List<NotificationEntity>();
    public ICollection<ConversationParticipantEntity> ConversationParticipants { get; set; } = new List<ConversationParticipantEntity>();
    public ICollection<MessageEntity> Messages { get; set; } = new List<MessageEntity>();
    public ICollection<BookmarkEntity> Bookmarks { get; set; } = new List<BookmarkEntity>();
    public ICollection<FollowEntity> Followers { get; set; } = new List<FollowEntity>();
    public ICollection<FollowEntity> Following { get; set; } = new List<FollowEntity>();
    public ICollection<UserSessionEntity> Sessions { get; set; } = new List<UserSessionEntity>();
}
