using System;
using System.Collections.Generic;
using System.Linq;
using Microsoft.EntityFrameworkCore;
using Nexus.Data.Entities;
using Nexus.Helpers;

namespace Nexus.Data;

public class AppDbInitializer
{
    private readonly NexusDbContext _dbContext;

    public AppDbInitializer(NexusDbContext dbContext)
    {
        _dbContext = dbContext;
    }

    public void Initialize()
    {
        _dbContext.Database.Migrate();

        if (_dbContext.Users.Any())
        {
            return;
        }

        var user = new UserEntity
        {
            Login = MockData.CurrentUser.Login,
            Email = MockData.CurrentUser.Email,
            PasswordHash = "demo",
        };

        var profile = new UserProfileEntity
        {
            User = user,
            FirstName = MockData.CurrentUser.Imie,
            LastName = MockData.CurrentUser.Nazwisko,
            AvatarUrl = MockData.CurrentUser.AvatarUrl,
            Bio = MockData.CurrentUser.Bio,
            BirthDate = MockData.CurrentUser.DataUrodzenia,
            Location = MockData.CurrentUser.Lokalizacja,
            Website = MockData.CurrentUser.Website,
            JoinedDate = MockData.CurrentUser.DataUtworzenia,
        };

        _dbContext.Users.Add(user);
        _dbContext.UserProfiles.Add(profile);

        var userLookup = new Dictionary<string, UserEntity>(StringComparer.OrdinalIgnoreCase)
        {
            [MockData.CurrentUser.Login] = user,
        };

        void EnsureUser(string login, string email, string firstName, string lastName, string avatarUrl)
        {
            if (userLookup.ContainsKey(login))
            {
                return;
            }

            var newUser = new UserEntity
            {
                Login = login,
                Email = email,
                PasswordHash = "demo",
            };

            var newProfile = new UserProfileEntity
            {
                User = newUser,
                FirstName = firstName,
                LastName = lastName,
                AvatarUrl = avatarUrl,
                JoinedDate = DateTime.UtcNow.ToString("yyyy-MM-dd"),
            };

            _dbContext.Users.Add(newUser);
            _dbContext.UserProfiles.Add(newProfile);
            userLookup[login] = newUser;
        }

        var authorMap = new Dictionary<string, (string First, string Last, string Avatar)>
        {
            ["anna_design"] = ("Anna", "Nowak", "https://images.unsplash.com/photo-1762522921456-cdfe882d36c3?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=400"),
            ["tomek_codes"] = ("Tomek", "Zieliński", "https://images.unsplash.com/photo-1720166067122-b5036f549ff9?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=400"),
            ["karolina_dev"] = ("Karolina", "Wiśniewska", "https://images.unsplash.com/photo-1569078449082-d264d9e239c5?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=400"),
            ["marekdev"] = (MockData.CurrentUser.Imie, MockData.CurrentUser.Nazwisko, MockData.CurrentUser.AvatarUrl),
        };

        foreach (var (login, data) in authorMap)
        {
            EnsureUser(login, $"{login}@nexus.pl", data.First, data.Last, data.Avatar);
        }

        foreach (var post in MockData.FeedPosts.Concat(MockData.UserPosts).Concat(MockData.BookmarkedPosts))
        {
            var author = userLookup[post.Author.Login];
            var postEntity = new PostEntity
            {
                Author = author,
                Text = post.Tekst,
                MediaUrl = post.MediaUrl,
                CreatedAt = DateTime.UtcNow,
                LikesCount = post.LikesCount,
                CommentsCount = post.CommentsCount,
                RetweetsCount = post.RetweetsCount,
            };

            foreach (var tag in post.Hashtags)
            {
                postEntity.Hashtags.Add(new PostHashtagEntity { Tag = tag });
            }

            _dbContext.Posts.Add(postEntity);

            if (post.Bookmarked)
            {
                _dbContext.Bookmarks.Add(new BookmarkEntity { User = user, Post = postEntity });
            }
        }

        foreach (var notification in MockData.Notifications)
        {
            var sender = userLookup[notification.User.Login];
            _dbContext.Notifications.Add(new NotificationEntity
            {
                Recipient = user,
                Actor = sender,
                Type = notification.Type,
                Preview = notification.Preview,
                CreatedAt = DateTime.UtcNow,
                IsRead = notification.IsRead,
            });
        }

        var conversations = new List<ConversationEntity>();
        foreach (var conversation in MockData.Conversations)
        {
            var convEntity = new ConversationEntity
            {
                LastMessage = conversation.LastMessage,
                UpdatedAt = DateTime.UtcNow,
            };

            var participant = userLookup[conversation.Login];
            convEntity.Participants.Add(new ConversationParticipantEntity { Conversation = convEntity, User = user });
            convEntity.Participants.Add(new ConversationParticipantEntity { Conversation = convEntity, User = participant });

            _dbContext.Conversations.Add(convEntity);
            conversations.Add(convEntity);
        }

        var firstConversation = conversations.FirstOrDefault();
        if (firstConversation != null)
        {
            foreach (var msg in MockData.ChatMessages)
            {
                var sender = msg.SenderId == 1 ? user : userLookup[MockData.Conversations.First().Login];
                _dbContext.Messages.Add(new MessageEntity
                {
                    Conversation = firstConversation,
                    Sender = sender,
                    Text = msg.Tekst,
                    CreatedAt = DateTime.UtcNow,
                    IsRead = msg.IsRead,
                });
            }
        }

        foreach (var session in MockData.Sessions)
        {
            _dbContext.Sessions.Add(new UserSessionEntity
            {
                User = user,
                Device = session.Device,
                IconGlyph = session.IconGlyph,
                Location = session.Location,
                Expiry = session.Expiry,
                Current = session.Current,
            });
        }

        _dbContext.SaveChanges();
    }
}
