<?xml version="1.0" encoding="utf-8"?>
<!--
    ExplorePage.xaml — Odkrywaj: wyszukiwarka + kategorie + popularne hashtagi.
    Odpowiednik: design/components/pages/ExplorePage.tsx
-->
<Page
    x:Class="Nexus.Views.ExplorePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Nexus.Models"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- Nagłówek z wyszukiwarką i kategoriami -->
            <Border BorderBrush="{StaticResource NexusBorderBrush}" BorderThickness="0,0,0,1"
                    Background="{StaticResource NexusCardBrush}" Padding="12">
                <StackPanel Spacing="10">
                    <!-- Pole wyszukiwania -->
                    <Grid>
                        <TextBox PlaceholderText="Szukaj na Nexus..."
                                 Style="{StaticResource NexusSearchBoxStyle}"
                                 Padding="32,8,8,8" />
                        <FontIcon Glyph="&#xE721;" FontSize="14"
                                  Foreground="{StaticResource NexusMutedForegroundBrush}"
                                  HorizontalAlignment="Left" VerticalAlignment="Center"
                                  Margin="10,0,0,0" />
                    </Grid>

                    <!-- Kategorie (chips) -->
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Style="{StaticResource NexusPrimaryButtonStyle}"
                                Padding="12,4" FontSize="12">
                            <TextBlock Text="Wszystko" FontSize="12" FontWeight="Medium" />
                        </Button>
                        <Button Style="{StaticResource NexusSecondaryButtonStyle}"
                                Background="{StaticResource NexusAccentSurfaceBrush}"
                                Padding="12,4" FontSize="12">
                            <TextBlock Text="Technologia" FontSize="12" />
                        </Button>
                        <Button Style="{StaticResource NexusSecondaryButtonStyle}"
                                Background="{StaticResource NexusAccentSurfaceBrush}"
                                Padding="12,4" FontSize="12">
                            <TextBlock Text="Gaming" FontSize="12" />
                        </Button>
                        <Button Style="{StaticResource NexusSecondaryButtonStyle}"
                                Background="{StaticResource NexusAccentSurfaceBrush}"
                                Padding="12,4" FontSize="12">
                            <TextBlock Text="Muzyka" FontSize="12" />
                        </Button>
                        <Button Style="{StaticResource NexusSecondaryButtonStyle}"
                                Background="{StaticResource NexusAccentSurfaceBrush}"
                                Padding="12,4" FontSize="12">
                            <TextBlock Text="Sport" FontSize="12" />
                        </Button>
                        <Button Style="{StaticResource NexusSecondaryButtonStyle}"
                                Background="{StaticResource NexusAccentSurfaceBrush}"
                                Padding="12,4" FontSize="12">
                            <TextBlock Text="Nauka" FontSize="12" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Popularne hashtagi -->
            <StackPanel Padding="16" Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                    <FontIcon Glyph="&#xE8B1;" FontSize="14"
                              Foreground="{StaticResource NexusVioletLightBrush}" />
                    <TextBlock Text="Popularne hashtagi" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource NexusForegroundBrush}" />
                </StackPanel>

                <ListView x:ConnectionId='2' x:Name="HashtagsListView"
                          SelectionMode="None" IsItemClickEnabled="False">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,2" />
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate                                    >
                            <Border x:ConnectionId='4' Padding="12" CornerRadius="4"
                                    BorderBrush="{StaticResource NexusBorderBrush}" BorderThickness="1"
                                    Background="#10FFFFFF">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Ikona hashtaga -->
                                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="4"
                                            Background="{StaticResource NexusVioletSubtleBrush}"
                                            BorderBrush="#308B5CF6" BorderThickness="1">
                                        <FontIcon Glyph="&#xF0E2;" FontSize="14"
                                                  Foreground="{StaticResource NexusVioletLightBrush}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>

                                    <!-- Nazwa + opis -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock x:ConnectionId='7'                            
                                                       FontWeight="SemiBold" FontSize="14"
                                                       Foreground="{StaticResource NexusForegroundBrush}" />
                                            <TextBlock FontSize="11"
                                                       Foreground="{StaticResource NexusMutedForegroundBrush}">
                                                <Run x:ConnectionId='8'                            />
                                                <Run Text=" postów" />
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock x:ConnectionId='6'                             FontSize="12"
                                                   Foreground="{StaticResource NexusMutedForegroundBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <!-- Numer rankingu -->
                                    <TextBlock Grid.Column="2" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource NexusMutedForegroundBrush}"
                                               VerticalAlignment="Center">
                                        <Run Text="#" /><Run x:ConnectionId='5'                    />
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>

