<?xml version="1.0" encoding="utf-8"?>
<!-- 
    LightTheme.xaml — Light variant kolorów i styli.
    Jasny motyw z fioletowym akcentem (#8B5CF6).
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════ -->
    <!--  PALETA KOLORÓW — Light Theme  -->
    <!-- ═══════════════════════════════════════════════════════════ -->

    <!-- Tła -->
    <Color x:Key="NexusBackgroundColor">#FFFAFAFA</Color>
    <Color x:Key="NexusCardColor">#FFFFFFFF</Color>
    <Color x:Key="NexusSidebarColor">#FFF5F5F5</Color>
    <Color x:Key="NexusAccentSurfaceColor">#FFF3F3F7</Color>
    <Color x:Key="NexusSecondaryColor">#FFF8F8FA</Color>
    <Color x:Key="NexusMutedColor">#FFECECF1</Color>
    <Color x:Key="NexusPopoverColor">#FFFFFFFF</Color>

    <!-- Tekst -->
    <Color x:Key="NexusForegroundColor">#FF1C1C21</Color>
    <Color x:Key="NexusMutedForegroundColor">#FF71717A</Color>

    <!-- Akcenty / Marka -->
    <Color x:Key="NexusVioletColor">#FF8B5CF6</Color>
    <Color x:Key="NexusVioletDarkColor">#FF7C3AED</Color>
    <Color x:Key="NexusVioletLightColor">#FFC4B5FD</Color>
    <Color x:Key="NexusVioletSubtleColor">#20A78BFA</Color>

    <!-- Obramowania -->
    <Color x:Key="NexusBorderColor">#14000000</Color>

    <!-- Akcje / Stany -->
    <Color x:Key="NexusDestructiveColor">#FFDC2626</Color>
    <Color x:Key="NexusGreenColor">#FF16A34A</Color>
    <Color x:Key="NexusBlueColor">#FF2563EB</Color>
    <Color x:Key="NexusOrangeColor">#FFEA580C</Color>
    <Color x:Key="NexusRedColor">#FFE11D48</Color>

    <!-- ═══════════════ BRUSHE ═══════════════ -->
    <SolidColorBrush x:Key="NexusBackgroundBrush" Color="{StaticResource NexusBackgroundColor}" />
    <SolidColorBrush x:Key="NexusCardBrush" Color="{StaticResource NexusCardColor}" />
    <SolidColorBrush x:Key="NexusSidebarBrush" Color="{StaticResource NexusSidebarColor}" />
    <SolidColorBrush x:Key="NexusAccentSurfaceBrush" Color="{StaticResource NexusAccentSurfaceColor}" />
    <SolidColorBrush x:Key="NexusSecondaryBrush" Color="{StaticResource NexusSecondaryColor}" />
    <SolidColorBrush x:Key="NexusMutedBrush" Color="{StaticResource NexusMutedColor}" />
    <SolidColorBrush x:Key="NexusPopoverBrush" Color="{StaticResource NexusPopoverColor}" />

    <SolidColorBrush x:Key="NexusForegroundBrush" Color="{StaticResource NexusForegroundColor}" />
    <SolidColorBrush x:Key="NexusMutedForegroundBrush" Color="{StaticResource NexusMutedForegroundColor}" />

    <SolidColorBrush x:Key="NexusVioletBrush" Color="{StaticResource NexusVioletColor}" />
    <SolidColorBrush x:Key="NexusVioletDarkBrush" Color="{StaticResource NexusVioletDarkColor}" />
    <SolidColorBrush x:Key="NexusVioletLightBrush" Color="{StaticResource NexusVioletLightColor}" />
    <SolidColorBrush x:Key="NexusVioletSubtleBrush" Color="{StaticResource NexusVioletSubtleColor}" />

    <SolidColorBrush x:Key="NexusBorderBrush" Color="{StaticResource NexusBorderColor}" />

    <SolidColorBrush x:Key="NexusDestructiveBrush" Color="{StaticResource NexusDestructiveColor}" />
    <SolidColorBrush x:Key="NexusGreenBrush" Color="{StaticResource NexusGreenColor}" />
    <SolidColorBrush x:Key="NexusBlueBrush" Color="{StaticResource NexusBlueColor}" />
    <SolidColorBrush x:Key="NexusOrangeBrush" Color="{StaticResource NexusOrangeColor}" />
    <SolidColorBrush x:Key="NexusRedBrush" Color="{StaticResource NexusRedColor}" />

    <!-- ═══════════════ NADPISANIA SYSTEMOWYCH ZASOBÓW WinUI ═══════════════ -->
    <!-- Wymuszenie jasnego motywu z naszą paletą kolorów -->

    <!-- NavigationView -->
    <SolidColorBrush x:Key="NavigationViewContentBackground" Color="{StaticResource NexusCardColor}" />
    <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="{StaticResource NexusSidebarColor}" />
    <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="{StaticResource NexusBorderColor}" />

    <!-- Tło okna / strony -->
    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="{StaticResource NexusBackgroundColor}" />
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush" Color="{StaticResource NexusBackgroundColor}" />

    <!-- ═══════════════ TYPOGRAFIA ═══════════════ -->
    <x:Double x:Key="NexusFontSizeCaption">11</x:Double>
    <x:Double x:Key="NexusFontSizeSmall">12</x:Double>
    <x:Double x:Key="NexusFontSizeBody">13</x:Double>
    <x:Double x:Key="NexusFontSizeSubtitle">14</x:Double>
    <x:Double x:Key="NexusFontSizeTitle">16</x:Double>
    <x:Double x:Key="NexusFontSizeHeader">20</x:Double>
    <CornerRadius x:Key="NexusCornerRadius">4</CornerRadius>
    <CornerRadius x:Key="NexusCornerRadiusMedium">6</CornerRadius>
    <CornerRadius x:Key="NexusCornerRadiusLarge">8</CornerRadius>
    <CornerRadius x:Key="NexusCornerRadiusFull">9999</CornerRadius>
    <Thickness x:Key="NexusBorderThickness">1</Thickness>

    <!-- ═══════════════ STYLE GLOBALNE ═══════════════ -->

    <!-- Nagłówek strony (np. "Strona główna", "Powiadomienia") -->
    <Style x:Key="NexusPageHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource NexusFontSizeTitle}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource NexusForegroundBrush}" />
    </Style>

    <!-- Podpis pod nagłówkiem -->
    <Style x:Key="NexusPageSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource NexusFontSizeSmall}" />
        <Setter Property="Foreground" Value="{StaticResource NexusMutedForegroundBrush}" />
    </Style>

    <!-- Zwykły tekst treści -->
    <Style x:Key="NexusBodyStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource NexusFontSizeBody}" />
        <Setter Property="Foreground" Value="{StaticResource NexusForegroundBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- Tekst wyciszony (daty, opisy, loginy) -->
    <Style x:Key="NexusMutedTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource NexusFontSizeSmall}" />
        <Setter Property="Foreground" Value="{StaticResource NexusMutedForegroundBrush}" />
    </Style>

    <!-- Nazwa użytkownika (bold) -->
    <Style x:Key="NexusDisplayNameStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource NexusFontSizeBody}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource NexusForegroundBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <!-- Karta / panel z zaokrąglonymi rogami -->
    <Style x:Key="NexusCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource NexusCardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource NexusBorderBrush}" />
        <Setter Property="BorderThickness" Value="{StaticResource NexusBorderThickness}" />
        <Setter Property="CornerRadius" Value="{StaticResource NexusCornerRadiusMedium}" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <!-- Przycisk główny (violet) — "Opublikuj", "Napisz post" -->
    <Style x:Key="NexusPrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource NexusVioletBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource NexusVioletDarkBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource NexusCornerRadius}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="{StaticResource NexusFontSizeBody}" />
        <Setter Property="Padding" Value="16,6,16,6" />
    </Style>

    <!-- Przycisk drugorzędny — "Edytuj profil", "Zmień" -->
    <Style x:Key="NexusSecondaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource NexusForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource NexusBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource NexusCornerRadius}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="FontSize" Value="{StaticResource NexusFontSizeBody}" />
        <Setter Property="Padding" Value="12,6,12,6" />
    </Style>

    <!-- Przycisk destrukcyjny (wyloguj, usuń) -->
    <Style x:Key="NexusDestructiveButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource NexusDestructiveBrush}" />
        <Setter Property="BorderBrush" Value="#30DC2626" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource NexusCornerRadius}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="FontSize" Value="{StaticResource NexusFontSizeBody}" />
        <Setter Property="Padding" Value="12,6,12,6" />
    </Style>

    <!-- Badge / etykieta (np. liczba powiadomień) -->
    <Style x:Key="NexusBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource NexusVioletBrush}" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Padding" Value="5,1,5,1" />
        <Setter Property="MinWidth" Value="18" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- Hashtag chip -->
    <Style x:Key="NexusHashtagChipStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource NexusVioletSubtleBrush}" />
        <Setter Property="BorderBrush" Value="#20A78BFA" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Padding" Value="8,2,8,2" />
    </Style>

    <!-- Pole tekstowe wyszukiwania -->
    <Style x:Key="NexusSearchBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource NexusAccentSurfaceBrush}" />
        <Setter Property="Foreground" Value="{StaticResource NexusForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource NexusBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource NexusCornerRadius}" />
        <Setter Property="FontSize" Value="{StaticResource NexusFontSizeSmall}" />
        <Setter Property="Padding" Value="8,6,8,6" />
    </Style>

    <!-- Separator linii (odpowiednik border-b border-border) -->
    <Style x:Key="NexusSeparatorStyle" TargetType="Border">
        <Setter Property="BorderBrush" Value="{StaticResource NexusBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>

    <!-- Etykieta sekcji ustawień (uppercase, muted) -->
    <Style x:Key="NexusSectionLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource NexusFontSizeCaption}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource NexusMutedForegroundBrush}" />
        <Setter Property="CharacterSpacing" Value="50" />
        <Setter Property="Padding" Value="4,0,0,0" />
    </Style>

</ResourceDictionary>

