<?xml version="1.0" encoding="utf-8"?>
<!--
    NotificationsPage.xaml — Powiadomienia z zakładkami Wszystkie/Wzmianki.
    Odpowiednik: design/components/pages/NotificationsPage.tsx
-->
<Page
    x:Class="Nexus.Views.NotificationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Nexus.Models"
    xmlns:helpers="using:Nexus.Helpers"
    Background="Transparent">

    <Page.Resources>
        <!-- Konwerter musi być w Page.Resources aby działał w DataTemplate -->
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- Nagłówek z zakładkami -->
            <Border BorderBrush="{StaticResource NexusBorderBrush}" BorderThickness="0,0,0,1"
                    Background="{StaticResource NexusCardBrush}">
                <StackPanel>
                    <TextBlock Text="Powiadomienia"
                               Style="{StaticResource NexusPageHeaderStyle}"
                               Margin="16,12,16,4" />
                    <StackPanel Orientation="Horizontal" Margin="8,0">
                        <Button x:ConnectionId='11' x:Name="TabAll" Content="Wszystkie" Tag="all"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource NexusForegroundBrush}"
                                FontWeight="SemiBold" FontSize="13" Padding="16,10"
                                                  />
                        <Button x:ConnectionId='12' x:Name="TabMentions" Content="Wzmianki" Tag="mentions"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource NexusMutedForegroundBrush}"
                                FontSize="13" Padding="16,10"
                                                  />
                    </StackPanel>
                    <Border Width="80" Height="2" CornerRadius="1"
                            Background="{StaticResource NexusVioletBrush}"
                            HorizontalAlignment="Left" Margin="16,0,0,0" />
                </StackPanel>
            </Border>

            <!-- Lista powiadomień -->
            <ListView x:ConnectionId='2' x:Name="NotificationsListView"
                      SelectionMode="None" IsItemClickEnabled="False">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="MinHeight" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate                                 >
                        <Border x:ConnectionId='4' Padding="12" BorderBrush="{StaticResource NexusBorderBrush}"
                                BorderThickness="0,0,0,1" Background="Transparent">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Ikona typu powiadomienia -->
                                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4"
                                        Background="#15FFFFFF"
                                        BorderBrush="{StaticResource NexusBorderBrush}" BorderThickness="1">
                                    <FontIcon FontSize="14" HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Foreground="{StaticResource NexusVioletLightBrush}"
                                              Glyph="&#xEA8F;" />
                                </Border>

                                <!-- Treść powiadomienia -->
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <!-- Awatar -->
                                        <Border Width="28" Height="28" CornerRadius="14"
                                                BorderBrush="{StaticResource NexusBorderBrush}" BorderThickness="1">
                                            <Border.Background>
                                                <ImageBrush Stretch="UniformToFill">
                                                    <ImageBrush.ImageSource>
                                                        <BitmapImage x:ConnectionId='10'                                    
                                                                     DecodePixelWidth="56" CreateOptions="IgnoreImageCache" />
                                                    </ImageBrush.ImageSource>
                                                </ImageBrush>
                                            </Border.Background>
                                        </Border>
                                        <!-- Badge typu -->
                                        <Border Background="{StaticResource NexusAccentSurfaceBrush}"
                                                BorderBrush="{StaticResource NexusBorderBrush}" BorderThickness="1"
                                                CornerRadius="3" Padding="6,2">
                                            <TextBlock x:ConnectionId='9'                      FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{StaticResource NexusMutedForegroundBrush}" />
                                        </Border>
                                    </StackPanel>

                                    <TextBlock FontSize="13" TextWrapping="Wrap"
                                               Foreground="{StaticResource NexusForegroundBrush}">
                                        <Run x:ConnectionId='8'                                  FontWeight="SemiBold" />
                                    </TextBlock>

                                    <!-- Preview tekstu (jeśli jest) -->
                                    <TextBlock x:ConnectionId='6'                         FontSize="12"
                                               Foreground="{StaticResource NexusMutedForegroundBrush}"
                                               TextTrimming="CharacterEllipsis"
                                                                                                                                                            />

                                    <TextBlock FontSize="11"
                                               Foreground="{StaticResource NexusMutedForegroundBrush}">
                                        <Run x:ConnectionId='7'                      />
                                        <Run Text=" temu" />
                                    </TextBlock>
                                </StackPanel>

                                <!-- Kropka nieprzeczytane (widoczna tylko gdy IsRead=false) -->
                                <Ellipse x:ConnectionId='5' Grid.Column="2" Width="6" Height="6"
                                         Fill="{StaticResource NexusVioletBrush}"
                                         VerticalAlignment="Top" Margin="0,4,0,0"
                                                                                                                                   />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </ScrollViewer>
</Page>

