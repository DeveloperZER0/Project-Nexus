<?xml version="1.0" encoding="utf-8"?>
<!--
    App.xaml — globalne zasoby aplikacji.
    Faktyczny motyw (Dark/Light/System) jest podmieniany w runtime przez App.xaml.cs::ApplyTheme.
    Tu ładujemy domyślnie Dark jako bazę; ApplyTheme może go zastąpić Light.
-->
<Application
    x:Class="Nexus.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Nexus"
    xmlns:helpers="using:Nexus.Helpers">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Bazowa paleta — ApplyTheme zamienia ją na wybrany motyw -->
                <ResourceDictionary Source="ms-appx:///Themes/DarkTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Konwertery globalne (dostępne dla wszystkich Page.Resources i Window scopes).
                 Niektóre Page mają je też duplikowane lokalnie, bo kompilator x:Bind w DataTemplate
                 nie zawsze przegląda Application.Resources. -->
            <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <helpers:BoolToAlignmentConverter x:Key="BoolToAlignmentConverter" />
            <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
            <helpers:BoolToBrushConverter x:Key="BoolToBrushConverter" />
            <helpers:FollowButtonTextConverter x:Key="FollowButtonTextConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>

