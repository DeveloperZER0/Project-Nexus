<?xml version="1.0" encoding="utf-8"?>
<!--
    ExplorePage.xaml — Odkrywaj: wyszukiwarka + kategorie + popularne hashtagi.
    Wyszukiwanie zwraca użytkowników i posty (NexusDataService.SearchUsers/SearchPosts).
-->
<Page
    x:Class="Nexus.Views.ExplorePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Nexus.Models"
    xmlns:helpers="using:Nexus.Helpers"
    Background="Transparent">

    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <helpers:StringToImageSourceConverter x:Key="StringToImageSourceConverter" />
        <helpers:FollowButtonTextConverter x:Key="FollowButtonTextConverter" />

        <!-- Karta posta w wynikach wyszukiwania -->
        <DataTemplate x:Key="SearchPostTemplate" x:DataType="models:Post">
            <Border Padding="14" BorderBrush="{StaticResource NexusBorderBrush}"
                    BorderThickness="0,0,0,1" Background="Transparent">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                            BorderBrush="{StaticResource NexusBorderBrush}" BorderThickness="1"
                            VerticalAlignment="Top">
                        <Border.Background>
                            <ImageBrush Stretch="UniformToFill">
                                <ImageBrush.ImageSource>
                                    <BitmapImage UriSource="{x:Bind Author.AvatarUrl}"
                                                 DecodePixelWidth="80" CreateOptions="IgnoreImageCache" />
                                </ImageBrush.ImageSource>
                            </ImageBrush>
                        </Border.Background>
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{x:Bind Author.DisplayName}"
                                       Style="{StaticResource NexusDisplayNameStyle}" />
                            <TextBlock FontSize="12" Foreground="{StaticResource NexusMutedForegroundBrush}">
                                <Run Text="{x:Bind Author.AtLogin}" />
                                <Run Text=" · " />
                                <Run Text="{x:Bind DataUtworzenia}" />
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Text="{x:Bind Tekst}" Style="{StaticResource NexusBodyStyle}"
                                   FontSize="14" LineHeight="21" />
                        <!-- Media (jeśli post zawiera obraz) -->
                        <Image Source="{x:Bind MediaUrl, Converter={StaticResource StringToImageSourceConverter}}"
                               Visibility="{x:Bind MediaUrl, Converter={StaticResource NullToVisibilityConverter}}"
                               Stretch="UniformToFill" MaxHeight="280" HorizontalAlignment="Left"
                               Margin="0,6,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Wiersz użytkownika w wynikach -->
        <DataTemplate x:Key="SearchUserTemplate" x:DataType="models:SuggestedUser">
            <Grid ColumnSpacing="10" Padding="12"
                  BorderBrush="{StaticResource NexusBorderBrush}" BorderThickness="0,0,0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                        BorderBrush="{StaticResource NexusBorderBrush}" BorderThickness="1">
                    <Border.Background>
                        <ImageBrush Stretch="UniformToFill">
                            <ImageBrush.ImageSource>
                                <BitmapImage UriSource="{x:Bind AvatarUrl}"
                                             DecodePixelWidth="80" CreateOptions="IgnoreImageCache" />
                            </ImageBrush.ImageSource>
                        </ImageBrush>
                    </Border.Background>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold" FontSize="13"
                               Foreground="{StaticResource NexusForegroundBrush}" />
                    <TextBlock Text="{x:Bind AtLogin}" FontSize="12"
                               Foreground="{StaticResource NexusMutedForegroundBrush}" />
                </StackPanel>
                <Button Grid.Column="2" Style="{StaticResource NexusPrimaryButtonStyle}"
                        Padding="12,4" FontSize="11" VerticalAlignment="Center"
                        Click="FollowUser_Click" Tag="{x:Bind}">
                    <TextBlock Text="{x:Bind IsFollowing, Converter={StaticResource FollowButtonTextConverter}}"
                               FontSize="11" FontWeight="SemiBold" />
                </Button>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- Nagłówek z wyszukiwarką i kategoriami -->
            <Border BorderBrush="{StaticResource NexusBorderBrush}" BorderThickness="0,0,0,1"
                    Background="{StaticResource NexusCardBrush}" Padding="12">
                <StackPanel Spacing="10">
                    <!-- Pole wyszukiwania -->
                    <Grid>
                        <TextBox x:Name="SearchBox"
                                 PlaceholderText="Szukaj na Nexus..."
                                 Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource NexusSearchBoxStyle}"
                                 Padding="32,8,8,8" />
                        <FontIcon Glyph="&#xE721;" FontSize="14"
                                  Foreground="{StaticResource NexusMutedForegroundBrush}"
                                  HorizontalAlignment="Left" VerticalAlignment="Center"
                                  Margin="10,0,0,0" IsHitTestVisible="False" />
                    </Grid>

                    <!-- Kategorie (chips) -->
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Click="Category_Click" Tag="Wszystko"
                                Style="{StaticResource NexusSecondaryButtonStyle}"
                                Background="{StaticResource NexusAccentSurfaceBrush}" Padding="12,4">
                            <TextBlock Text="Wszystko" FontSize="12" />
                        </Button>
                        <Button Click="Category_Click" Tag="Technologia"
                                Style="{StaticResource NexusSecondaryButtonStyle}"
                                Background="{StaticResource NexusAccentSurfaceBrush}" Padding="12,4">
                            <TextBlock Text="Technologia" FontSize="12" />
                        </Button>
                        <Button Click="Category_Click" Tag="Gaming"
                                Style="{StaticResource NexusSecondaryButtonStyle}"
                                Background="{StaticResource NexusAccentSurfaceBrush}" Padding="12,4">
                            <TextBlock Text="Gaming" FontSize="12" />
                        </Button>
                        <Button Click="Category_Click" Tag="Muzyka"
                                Style="{StaticResource NexusSecondaryButtonStyle}"
                                Background="{StaticResource NexusAccentSurfaceBrush}" Padding="12,4">
                            <TextBlock Text="Muzyka" FontSize="12" />
                        </Button>
                        <Button Click="Category_Click" Tag="Sport"
                                Style="{StaticResource NexusSecondaryButtonStyle}"
                                Background="{StaticResource NexusAccentSurfaceBrush}" Padding="12,4">
                            <TextBlock Text="Sport" FontSize="12" />
                        </Button>
                        <Button Click="Category_Click" Tag="Nauka"
                                Style="{StaticResource NexusSecondaryButtonStyle}"
                                Background="{StaticResource NexusAccentSurfaceBrush}" Padding="12,4">
                            <TextBlock Text="Nauka" FontSize="12" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ═══ WYNIKI: UŻYTKOWNICY ═══ -->
            <StackPanel Padding="16,12,16,0" Spacing="6"
                        Visibility="{x:Bind ViewModel.HasUserResults, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="Osoby" FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource NexusForegroundBrush}" />
                <ListView ItemsSource="{x:Bind ViewModel.SearchedUsers}"
                          ItemTemplate="{StaticResource SearchUserTemplate}"
                          SelectionMode="None" IsItemClickEnabled="True"
                          ItemClick="UserResult_ItemClick">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </StackPanel>

            <!-- ═══ WYNIKI: POSTY ═══ -->
            <StackPanel Padding="16,12,16,0" Spacing="6"
                        Visibility="{x:Bind ViewModel.HasPostResults, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="Posty" FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource NexusForegroundBrush}" />
                <ListView ItemsSource="{x:Bind ViewModel.SearchedPosts}"
                          ItemTemplate="{StaticResource SearchPostTemplate}"
                          SelectionMode="None" IsItemClickEnabled="False">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </StackPanel>

            <!-- Brak wyników -->
            <TextBlock Text="Brak wyników dla podanego zapytania."
                       Padding="16,24" FontSize="13" HorizontalAlignment="Center"
                       Foreground="{StaticResource NexusMutedForegroundBrush}"
                       Visibility="{x:Bind ViewModel.NoResults, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

            <!-- ═══ POPULARNE HASHTAGI (gdy brak wyszukiwania) ═══ -->
            <StackPanel Padding="16" Spacing="6"
                        Visibility="{x:Bind ViewModel.ShowTrending, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                    <FontIcon Glyph="&#xE8B1;" FontSize="14"
                              Foreground="{StaticResource NexusVioletLightBrush}" />
                    <TextBlock Text="Popularne hashtagi" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource NexusForegroundBrush}" />
                </StackPanel>

                <ListView x:Name="HashtagsListView"
                          SelectionMode="None" IsItemClickEnabled="True"
                          ItemClick="Trending_ItemClick">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,2" />
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:TrendingHashtag">
                            <Border Padding="12" CornerRadius="4"
                                    BorderBrush="{StaticResource NexusBorderBrush}" BorderThickness="1"
                                    Background="#10FFFFFF">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Ikona hashtaga -->
                                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="4"
                                            Background="{StaticResource NexusVioletSubtleBrush}"
                                            BorderBrush="#308B5CF6" BorderThickness="1">
                                        <FontIcon Glyph="&#xF0E2;" FontSize="14"
                                                  Foreground="{StaticResource NexusVioletLightBrush}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>

                                    <!-- Nazwa + opis -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{x:Bind DisplayName}"
                                                       FontWeight="SemiBold" FontSize="14"
                                                       Foreground="{StaticResource NexusForegroundBrush}" />
                                            <TextBlock FontSize="11"
                                                       Foreground="{StaticResource NexusMutedForegroundBrush}">
                                                <Run Text="{x:Bind PostsCount}" />
                                                <Run Text=" postów" />
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Text="{x:Bind Description}" FontSize="12"
                                                   Foreground="{StaticResource NexusMutedForegroundBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <!-- Numer rankingu -->
                                    <TextBlock Grid.Column="2" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource NexusMutedForegroundBrush}"
                                               VerticalAlignment="Center">
                                        <Run Text="#" /><Run Text="{x:Bind Id}" />
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
