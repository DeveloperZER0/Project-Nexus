<?xml version="1.0" encoding="utf-8"?>
<!--
    ProfilePage.xaml — Profil użytkownika z banerem, statystykami i postami.
    Odpowiednik: design/components/pages/ProfilePage.tsx
-->
<Page
    x:Class="Nexus.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Nexus.Models"
    xmlns:helpers="using:Nexus.Helpers"
    Background="Transparent">

    <Page.Resources>
        <helpers:StringToImageSourceConverter x:Key="StringToImageSourceConverter" />
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />

        <!-- Reużywalny template posta (taki sam jak na HomePage) -->
        <DataTemplate x:Key="PostCardTemplate" x:DataType="models:Post">
            <Border Padding="14" BorderBrush="{StaticResource NexusBorderBrush}"
                    BorderThickness="0,0,0,1" Background="Transparent">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                            BorderBrush="{StaticResource NexusBorderBrush}" BorderThickness="1"
                            VerticalAlignment="Top">
                        <Border.Background>
                            <ImageBrush Stretch="UniformToFill">
                                <ImageBrush.ImageSource>
                                    <BitmapImage UriSource="{x:Bind Author.AvatarUrl}"
                                                 DecodePixelWidth="80" CreateOptions="IgnoreImageCache" />
                                </ImageBrush.ImageSource>
                            </ImageBrush>
                        </Border.Background>
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{x:Bind Author.DisplayName}"
                                       Style="{StaticResource NexusDisplayNameStyle}" />
                            <TextBlock FontSize="12" Foreground="{StaticResource NexusMutedForegroundBrush}">
                                <Run Text="{x:Bind Author.AtLogin}" />
                                <Run Text=" · " />
                                <Run Text="{x:Bind DataUtworzenia}" />
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Text="{x:Bind Tekst}" Style="{StaticResource NexusBodyStyle}"
                                   FontSize="14" LineHeight="21" />
                        <Border CornerRadius="12" Margin="0,8,0,0" HorizontalAlignment="Left"
                                BorderBrush="{StaticResource NexusBorderBrush}" BorderThickness="1"
                                Visibility="{x:Bind MediaUrl, Converter={StaticResource NullToVisibilityConverter}}">
                            <Image Source="{x:Bind MediaUrl, Converter={StaticResource StringToImageSourceConverter}}"
                                   Stretch="UniformToFill" MaxHeight="320" />
                        </Border>
                        <ItemsRepeater ItemsSource="{x:Bind Hashtags}" Margin="0,4,0,0">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="6" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Border Style="{StaticResource NexusHashtagChipStyle}">
                                        <TextBlock FontSize="11" FontWeight="Medium"
                                                   Foreground="{StaticResource NexusVioletLightBrush}">
                                            <Run Text="#" /><Run Text="{x:Bind}" />
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                        <StackPanel Orientation="Horizontal" Spacing="2" Margin="0,6,0,0">
                            <Button Background="Transparent" BorderThickness="0" Padding="6,4" CornerRadius="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE8BD;" FontSize="14" Foreground="{StaticResource NexusMutedForegroundBrush}" />
                                    <TextBlock Text="{x:Bind CommentsCount}" FontSize="11" Foreground="{StaticResource NexusMutedForegroundBrush}" />
                                </StackPanel>
                            </Button>
                            <Button Background="Transparent" BorderThickness="0" Padding="6,4" CornerRadius="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE8EB;" FontSize="14" Foreground="{StaticResource NexusMutedForegroundBrush}" />
                                    <TextBlock Text="{x:Bind RetweetsCount}" FontSize="11" Foreground="{StaticResource NexusMutedForegroundBrush}" />
                                </StackPanel>
                            </Button>
                            <Button Background="Transparent" BorderThickness="0" Padding="6,4" CornerRadius="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xEB51;" FontSize="14" Foreground="{StaticResource NexusMutedForegroundBrush}" />
                                    <TextBlock Text="{x:Bind LikesCount}" FontSize="11" Foreground="{StaticResource NexusMutedForegroundBrush}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- Baner profilu — gradient fioletowy -->
            <Grid Height="160">
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF7C3AED" Offset="0.0" />
                            <GradientStop Color="#FF9333EA" Offset="0.5" />
                            <GradientStop Color="#FF4338CA" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Awatar nakładany na baner -->
                <Border Width="112" Height="112" CornerRadius="56"
                        BorderBrush="{StaticResource NexusBackgroundBrush}" BorderThickness="4"
                        VerticalAlignment="Bottom" HorizontalAlignment="Left"
                        Margin="16,-56,0,0" Canvas.ZIndex="10">
                    <Border.Background>
                        <ImageBrush Stretch="UniformToFill">
                            <ImageBrush.ImageSource>
                                <BitmapImage UriSource="https://images.unsplash.com/photo-1543132220-e7fef0b974e7?crop=entropy&amp;cs=tinysrgb&amp;fit=max&amp;fm=jpg&amp;q=80&amp;w=400"
                                             CreateOptions="IgnoreImageCache" />
                            </ImageBrush.ImageSource>
                        </ImageBrush>
                    </Border.Background>
                </Border>
            </Grid>

            <!-- Dane profilu -->
            <StackPanel Padding="16,56,16,12" Spacing="6"
                        BorderBrush="{StaticResource NexusBorderBrush}" BorderThickness="0,0,0,1">

                <!-- Przycisk edytuj profil — widoczny tylko dla aktualnego użytkownika -->
                <Button Style="{StaticResource NexusSecondaryButtonStyle}"
                        HorizontalAlignment="Right" Margin="0,-40,0,0"
                        Command="{x:Bind ViewModel.EditProfileCommand}"
                        Visibility="{x:Bind ViewModel.IsCurrentUser, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE70F;" FontSize="12" />
                        <TextBlock Text="Edytuj profil" FontSize="12" FontWeight="Medium" />
                    </StackPanel>
                </Button>

                <!-- Przycisk obserwuj — widoczny tylko na cudzym profilu -->
                <Button Style="{StaticResource NexusPrimaryButtonStyle}"
                        HorizontalAlignment="Right" Margin="0,-40,0,0"
                        Command="{x:Bind ViewModel.FollowCommand}"
                        Visibility="{x:Bind ViewModel.ShowFollowButton, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                    <TextBlock Text="{x:Bind ViewModel.IsFollowing, Converter={StaticResource FollowButtonTextConverter}, Mode=OneWay}"
                               FontSize="12" FontWeight="Medium" />
                </Button>

                <TextBlock x:Name="ProfileName" FontSize="20" FontWeight="SemiBold"
                           Foreground="{StaticResource NexusForegroundBrush}" />
                <TextBlock x:Name="ProfileLogin" FontSize="13"
                           Foreground="{StaticResource NexusMutedForegroundBrush}" />
                <TextBlock x:Name="ProfileBio" FontSize="14" TextWrapping="Wrap"
                           Foreground="{StaticResource NexusForegroundBrush}" Margin="0,6,0,0"
                           LineHeight="21" />

                <!-- Szczegóły profilu (2 kolumny) -->
                <Grid Margin="0,8,0,0" RowSpacing="4" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE779;" FontSize="12" Foreground="{StaticResource NexusMutedForegroundBrush}" />
                        <TextBlock x:Name="ProfileLoginDetail" FontSize="12" Foreground="{StaticResource NexusMutedForegroundBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE715;" FontSize="12" Foreground="{StaticResource NexusMutedForegroundBrush}" />
                        <TextBlock x:Name="ProfileEmail" FontSize="12" Foreground="{StaticResource NexusMutedForegroundBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE81D;" FontSize="12" Foreground="{StaticResource NexusMutedForegroundBrush}" />
                        <TextBlock x:Name="ProfileLocation" FontSize="12" Foreground="{StaticResource NexusMutedForegroundBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE71B;" FontSize="12" Foreground="{StaticResource NexusMutedForegroundBrush}" />
                        <TextBlock x:Name="ProfileWebsite" FontSize="12" Foreground="{StaticResource NexusVioletLightBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xED54;" FontSize="12" Foreground="{StaticResource NexusMutedForegroundBrush}" />
                        <TextBlock x:Name="ProfileBirth" FontSize="12" Foreground="{StaticResource NexusMutedForegroundBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE787;" FontSize="12" Foreground="{StaticResource NexusMutedForegroundBrush}" />
                        <TextBlock x:Name="ProfileJoined" FontSize="12" Foreground="{StaticResource NexusMutedForegroundBrush}" />
                    </StackPanel>
                </Grid>

                <!-- Statystyki (3 karty) -->
                <Grid Margin="0,12,0,0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="4" Padding="12,8"
                            BorderBrush="{StaticResource NexusBorderBrush}" BorderThickness="1"
                            Background="#10FFFFFF">
                        <StackPanel>
                            <TextBlock x:Name="StatPosts" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource NexusForegroundBrush}" />
                            <TextBlock Text="Posty" FontSize="11"
                                       Foreground="{StaticResource NexusMutedForegroundBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" CornerRadius="4" Padding="12,8"
                            BorderBrush="{StaticResource NexusBorderBrush}" BorderThickness="1"
                            Background="#10FFFFFF">
                        <StackPanel>
                            <TextBlock x:Name="StatFollowing" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource NexusForegroundBrush}" />
                            <TextBlock Text="Obserwowani" FontSize="11"
                                       Foreground="{StaticResource NexusMutedForegroundBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" CornerRadius="4" Padding="12,8"
                            BorderBrush="{StaticResource NexusBorderBrush}" BorderThickness="1"
                            Background="#10FFFFFF">
                        <StackPanel>
                            <TextBlock x:Name="StatFollowers" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource NexusForegroundBrush}" />
                            <TextBlock Text="Obserwujący" FontSize="11"
                                       Foreground="{StaticResource NexusMutedForegroundBrush}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <!-- Zakładki: Posty / Odpowiedzi / Media / Polubienia -->
            <Border BorderBrush="{StaticResource NexusBorderBrush}" BorderThickness="0,0,0,1">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="8,0">
                        <Button x:Name="TabPosts" Content="Posty" Tag="posts" Click="OnTabClicked"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource NexusForegroundBrush}"
                                FontWeight="SemiBold" FontSize="13" Padding="16,10" />
                        <Button x:Name="TabReplies" Content="Odpowiedzi" Tag="replies" Click="OnTabClicked"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource NexusMutedForegroundBrush}"
                                FontSize="13" Padding="16,10" />
                        <Button x:Name="TabMedia" Content="Media" Tag="media" Click="OnTabClicked"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource NexusMutedForegroundBrush}"
                                FontSize="13" Padding="16,10" />
                        <Button x:Name="TabLikes" Content="Polubienia" Tag="likes" Click="OnTabClicked"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource NexusMutedForegroundBrush}"
                                FontSize="13" Padding="16,10" />
                    </StackPanel>
                    <Border Width="50" Height="2" CornerRadius="1"
                            Background="{StaticResource NexusVioletBrush}"
                            HorizontalAlignment="Left" Margin="16,0,0,0" />
                </StackPanel>
            </Border>

            <!-- Lista postów użytkownika -->
            <ListView x:Name="UserPostsListView"
                      SelectionMode="None" IsItemClickEnabled="False"
                      ItemTemplate="{StaticResource PostCardTemplate}">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="MinHeight" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
        </StackPanel>
    </ScrollViewer>
</Page>
