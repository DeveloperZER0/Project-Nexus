<?xml version="1.0" encoding="utf-8"?>
<!--
    RegisterPage.xaml — formularz rejestracji nowego konta.
    Po sukcesie nawigacja wraca do LoginPage z komunikatem powodzenia.
-->
<Page
    x:Class="Nexus.Views.RegisterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Nexus.ViewModels"
    xmlns:helpers="using:Nexus.Helpers"
    Background="Transparent">

    <Page.Resources>
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Border MaxWidth="440" MinWidth="320"
                    Background="{StaticResource NexusCardBrush}"
                    BorderBrush="{StaticResource NexusBorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="32" Margin="0,40,0,40"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="8">
                    <!-- Logo + tytuł -->
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,0,0,4">
                        <Border Background="{StaticResource NexusVioletBrush}" CornerRadius="6"
                                Width="32" Height="32">
                            <FontIcon Glyph="&#xF0E2;" FontSize="16" Foreground="White"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Nexus" FontSize="20" FontWeight="SemiBold"
                                   Foreground="{StaticResource NexusForegroundBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="Utwórz konto" FontSize="13"
                               Foreground="{StaticResource NexusMutedForegroundBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8" />

                    <!-- Imię + Nazwisko (2 kolumny) -->
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Imię" FontSize="12"
                                       Foreground="{StaticResource NexusMutedForegroundBrush}" />
                            <TextBox PlaceholderText="Imię"
                                     Text="{x:Bind ViewModel.FirstName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource NexusSearchBoxStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="Nazwisko" FontSize="12"
                                       Foreground="{StaticResource NexusMutedForegroundBrush}" />
                            <TextBox PlaceholderText="Nazwisko"
                                     Text="{x:Bind ViewModel.LastName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource NexusSearchBoxStyle}" />
                        </StackPanel>
                    </Grid>

                    <!-- Login -->
                    <TextBlock Text="Login" FontSize="12"
                               Foreground="{StaticResource NexusMutedForegroundBrush}"
                               Margin="0,4,0,0" />
                    <TextBox x:Name="LoginField"
                             PlaceholderText="np. anna_dev"
                             Text="{x:Bind ViewModel.Login, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource NexusSearchBoxStyle}" />

                    <!-- Email -->
                    <TextBlock Text="Email" FontSize="12"
                               Foreground="{StaticResource NexusMutedForegroundBrush}"
                               Margin="0,4,0,0" />
                    <TextBox PlaceholderText="anna@example.com"
                             Text="{x:Bind ViewModel.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource NexusSearchBoxStyle}"
                             InputScope="EmailNameOrAddress" />

                    <!-- Hasło + powtórzenie -->
                    <TextBlock Text="Hasło (min. 8 znaków)" FontSize="12"
                               Foreground="{StaticResource NexusMutedForegroundBrush}"
                               Margin="0,4,0,0" />
                    <PasswordBox x:Name="PasswordField"
                                 PlaceholderText="Hasło"
                                 PasswordChanged="PasswordField_PasswordChanged" />

                    <TextBlock Text="Powtórz hasło" FontSize="12"
                               Foreground="{StaticResource NexusMutedForegroundBrush}"
                               Margin="0,4,0,0" />
                    <PasswordBox x:Name="ConfirmField"
                                 PlaceholderText="Powtórz hasło"
                                 PasswordChanged="ConfirmField_PasswordChanged" />

                    <!-- Błąd -->
                    <Border Background="#202EF4444" CornerRadius="4" Padding="10,6"
                            BorderBrush="{StaticResource NexusDestructiveBrush}" BorderThickness="1"
                            Margin="0,4,0,0"
                            Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                        <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                                   Foreground="{StaticResource NexusDestructiveBrush}"
                                   FontSize="12" TextWrapping="Wrap" />
                    </Border>

                    <!-- Submit -->
                    <Button Style="{StaticResource NexusPrimaryButtonStyle}"
                            HorizontalAlignment="Stretch" Margin="0,8,0,0"
                            Click="SubmitButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <ProgressRing Width="14" Height="14"
                                          IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                          Foreground="White"
                                          Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <TextBlock Text="Zarejestruj się" FontSize="13" FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>

                    <!-- Link do logowania -->
                    <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" Margin="0,12,0,0">
                        <TextBlock Text="Masz już konto?" FontSize="12"
                                   Foreground="{StaticResource NexusMutedForegroundBrush}"
                                   VerticalAlignment="Center" />
                        <HyperlinkButton Content="Zaloguj się" Padding="4,0" FontSize="12"
                                         Click="GoToLogin_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
