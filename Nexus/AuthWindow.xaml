<?xml version="1.0" encoding="utf-8"?>
<!--
    AuthWindow.xaml — okno autoryzacji (Login / Register).
    Aktywne przed zalogowaniem; po LoginSucceeded App zamienia je na MainWindow.
-->
<Window
    x:Class="Nexus.AuthWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Nexus — Logowanie">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="{StaticResource NexusBackgroundBrush}">
        <Frame x:Name="AuthFrame" />
    </Grid>
</Window>
